---
import { siteConfig } from '../../config/site';

const deploymentCards = [
  {
    name: 'Immich',
    icon: 'photo_library',
    badge: 'PHOTOS',
    badgeClass: 'deployment-card-badge-green',
    host: 'photos.pratik-labs.xyz',
    description:
      'Self-hosted photo management with GPU-accelerated machine learning for face detection and smart search.',
    buttonLabel: 'Open Service',
    href: siteConfig.immichUrl,
  },
  {
    name: 'Argo CD',
    icon: 'hub',
    badge: 'GITOPS',
    badgeClass: 'deployment-card-badge-red',
    host: 'argocd.pratik-labs.xyz',
    description:
      'GitOps continuous delivery dashboard for synchronizing Kubernetes workloads from Git state.',
    buttonLabel: 'View Dashboard',
    href: siteConfig.argoCdUrl,
  },
  {
    name: 'Grafana',
    icon: 'monitoring',
    badge: 'MONITORING',
    badgeClass: 'deployment-card-badge-blue',
    host: 'grafana.pratik-labs.xyz',
    description: 'Metrics visualization dashboard connected to Prometheus for cluster and application monitoring.',
    buttonLabel: 'View Dashboard',
    href: siteConfig.grafanaUrl,
  },
  {
    name: 'Uptime Kuma',
    icon: 'monitor_heart',
    badge: 'STATUS',
    badgeClass: 'deployment-card-badge-cyan',
    host: 'status.pratik-labs.xyz',
    description: 'Service uptime monitoring dashboard tracking availability of public endpoints with push alerts.',
    buttonLabel: 'View Status',
    href: siteConfig.uptimeKumaUrl,
  },
] as const;
---

<section id="deployments" class="deployments-section">
  <div class="reveal-section">
    <header class="deployments-header reveal-item" style="--reveal-order: 0;">
      <h2 class="deployments-title">Private Cloud Services</h2>
      <p class="deployments-subtitle">Core Services Running in the Homelab</p>
    </header>

    <div class="deployments-grid reveal-item" style="--reveal-order: 1;">
      {
        deploymentCards.map((card) => (
          <article class="deployment-card deployment-card-interactive">
            <header class="deployment-card-header">
              <span class="deployment-card-icon-box" aria-hidden="true">
                <span class="material-symbols-outlined deployment-card-symbol">{card.icon}</span>
              </span>
              <span class={`deployment-card-badge ${card.badgeClass}`}>{card.badge}</span>
            </header>

            <h3 class="deployment-card-title">{card.name}</h3>
            <p class="deployment-card-host">{card.host}</p>
            <p class="deployment-card-text">{card.description}</p>

            <a
              class="deployment-card-button deployment-card-button-solid btn-glow-hover"
              href={card.href}
              target="_blank"
              rel="noopener noreferrer"
            >
              {card.buttonLabel}
            </a>
          </article>
        ))
      }
    </div>
  </div>
</section>
