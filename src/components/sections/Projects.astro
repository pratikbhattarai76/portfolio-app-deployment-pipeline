---
import { siteConfig } from '../../config/site';

const infrastructureAccessItems = [
  'Cloudflare Tunnel for public ingress',
  'Nginx Proxy Manager for internal routing',
  'SSH access secured with key-based authentication',
  'Segmented Docker networking for service isolation',
];

const operationsObservabilityItems = [
  'Multi-service Docker Compose deployment',
  'Monitoring with Prometheus and Grafana',
  'Uptime monitoring with Uptime Kuma',
  'Automation and sync workflows using Ansible',
];

const privateCloudStackGroups = [
  {
    label: 'Container Platform',
    items: ['Docker Engine', 'Docker Compose'],
  },
  {
    label: 'Ingress & Networking',
    items: ['Nginx Proxy Manager', 'Cloudflared'],
  },
  {
    label: 'Observability',
    items: ['Prometheus', 'Grafana', 'Uptime Kuma'],
  },
  {
    label: 'Automation',
    items: ['Ansible', 'GitHub Actions'],
  },
  {
    label: 'Infrastructure',
    items: ['Ubuntu Server', 'Storage Architecture'],
  },
  {
    label: 'Administrative Access',
    items: ['Tailscale'],
  },
];

const malaiDeuCloudDeliveryItems = [
  'AWS EC2 for containerized application hosting',
  'Amazon S3 for file storage',
  'IAM role-based access control',
  'Application Load Balancer (ALB) with Cloudflare for domain and HTTPS routing',
];

const malaiDeuDeploymentFlowItems = [
  'Dockerized application runtime',
  'GitHub Actions CI/CD pipeline',
  'GHCR image build and publishing',
  'Automated SSH-based deployment to EC2',
];

const malaiDeuStackGroups = [
  {
    label: 'Application Stack',
    items: ['Node.js', 'Express.js', 'EJS'],
  },
  {
    label: 'Cloud & Infrastructure',
    items: ['Application Load Balancer (ALB)', 'Amazon S3', 'IAM Role', 'EC2', 'AWS SDK'],
  },
  {
    label: 'Deployment & CI/CD',
    items: ['Docker', 'GitHub Actions', 'GHCR'],
  },
  {
    label: 'Network & Access',
    items: ['Cloudflare'],
  },
  {
    label: 'Infrastructure as Code',
    items: ['Terraform'],
  },
  {
    label: 'Configuration & Automation',
    items: ['Ansible'],
  },
];

const portfolioRuntimeItems = [
  'Astro-based portfolio application',
  'Node.js runtime for SSR features',
  'Contact form integration',
  'Runtime environment variable injection',
];

const portfolioDeliveryWorkflowItems = [
  'GitHub Actions image build and verification',
  'GHCR image publishing',
  'Automated manifest updates in Git',
  'Argo CD auto-sync to k3s workloads',
];

const portfolioStackGroups = [
  {
    label: 'Frontend',
    items: ['Astro', 'TypeScript', 'Tailwind CSS'],
  },
  {
    label: 'Runtime',
    items: ['Node.js', 'SSR', 'Nodemailer'],
  },
  {
    label: 'Delivery',
    items: ['Docker', 'GitHub Actions', 'GHCR'],
  },
  {
    label: 'Operations',
    items: ['Kubernetes (k3s)', 'Argo CD', 'Helm'],
  },
];

const k8sInfrastructureGitOpsItems = [
  'Ansible-automated server provisioning and k3s installation',
  'Argo CD with auto-sync managing all deployments from Git',
  'CI/CD pipeline: GitHub Actions -> GHCR -> manifest update -> Argo CD deploys',
  'Remote kubectl access via Tailscale',
];

const k8sDeployedServicesItems = [
  'Portfolio app with automated CI/CD pipeline',
  'Immich photo management with GPU-accelerated ML',
  'Prometheus, Grafana, Alertmanager monitoring stack',
  'Uptime Kuma with Gotify push notifications',
];

const k8sStackGroups = [
  {
    label: 'Orchestration',
    items: ['Kubernetes (k3s)'],
  },
  {
    label: 'GitOps',
    items: ['Argo CD'],
  },
  {
    label: 'Ingress',
    items: ['Traefik', 'Cloudflare Tunnel'],
  },
  {
    label: 'Monitoring',
    items: ['Prometheus', 'Grafana', 'Alertmanager'],
  },
  {
    label: 'Automation',
    items: ['Ansible', 'GitHub Actions'],
  },
  {
    label: 'Infrastructure',
    items: ['Ubuntu Server', 'Tailscale'],
  },
];
---

<section id="projects" class="projects-section">
  <div class="projects-shell">
    <header class="projects-header reveal-section">
      <div class="projects-heading-group reveal-item" style="--reveal-order: 0;">
        <h2 class="projects-title">Projects</h2>
      </div>
    </header>

    <section id="k8s-homelab-platform" class="project-feature reveal-section border-t border-cyber-border/20" style="order: 1;">
      <div class="project-feature-heading">
        <div class="project-feature-heading-row">
          <h3 class="project-feature-title reveal-item" style="--reveal-order: 0;">
            Kubernetes Homelab Platform
          </h3>
          <a
            class="project-feature-link btn-glow-hover reveal-item"
            href={siteConfig.k8sHomelabPlatformUrl}
            target="_blank"
            rel="noopener noreferrer"
            style="--reveal-order: 1;"
          >
            <img
              src="/icons/github.svg"
              alt=""
              aria-hidden="true"
              class="project-feature-link-icon"
              loading="lazy"
            />
            <span>View on GitHub</span>
            <span class="material-symbols-outlined project-feature-link-arrow" aria-hidden="true">
              north_east
            </span>
          </a>
        </div>
        <div class="project-feature-rule reveal-item" style="--reveal-order: 2;" aria-hidden="true">
        </div>
      </div>

      <div class="project-feature-layout">
        <div class="project-feature-details">
          <p class="project-feature-description reveal-item" style="--reveal-order: 3;">
            Single-node k3s platform on bare metal managed with infrastructure as code. Server
            provisioning and cluster bootstrapping are automated with Ansible, while Argo CD
            continuously reconciles workloads from Git. The delivery pipeline builds and publishes
            images, updates manifests, and promotes changes into the cluster with auditable GitOps
            history.
          </p>

          <div class="project-pillars">
            <article class="project-pillar glass-effect reveal-item" style="--reveal-order: 4;">
              <h4 class="project-pillar-title">Infrastructure &amp; GitOps</h4>
              <ul class="project-pillar-list">
                {
                  k8sInfrastructureGitOpsItems.map((item) => (
                    <li class="project-pillar-item">
                      <span class="project-pillar-arrow" aria-hidden="true">
                        →
                      </span>
                      <span>{item}</span>
                    </li>
                  ))
                }
              </ul>
            </article>

            <article class="project-pillar glass-effect reveal-item" style="--reveal-order: 5;">
              <h4 class="project-pillar-title">Deployed Services</h4>
              <ul class="project-pillar-list">
                {
                  k8sDeployedServicesItems.map((item) => (
                    <li class="project-pillar-item">
                      <span class="project-pillar-arrow" aria-hidden="true">
                        →
                      </span>
                      <span>{item}</span>
                    </li>
                  ))
                }
              </ul>
            </article>
          </div>
        </div>

        <div class="project-network-panel glass-effect reveal-item" style="--reveal-order: 6;">
          <div class="project-network-label">
            <div class="project-network-indicator" aria-hidden="true"></div>
            <span>Platform Architecture</span>
          </div>

          <svg class="project-network-visual" viewBox="0 0 600 550" preserveAspectRatio="xMidYMid meet">
            <defs>
              <filter id="k8s-packet-glow" x="-200%" y="-200%" width="400%" height="400%">
                <feGaussianBlur stdDeviation="2" result="blur"></feGaussianBlur>
                <feMerge>
                  <feMergeNode in="blur"></feMergeNode>
                  <feMergeNode in="SourceGraphic"></feMergeNode>
                </feMerge>
              </filter>
            </defs>

            <g transform="translate(300, 90)">
              <rect class="project-network-node project-network-node-edge" fill="var(--diagram-node-fill)" height="34" rx="5" stroke="var(--diagram-accent)" stroke-width="1" width="126" x="-63" y="-17"></rect>
              <text fill="var(--diagram-accent)" font-family="Inter" font-size="9" text-anchor="middle" dominant-baseline="middle">
                Git Repo
              </text>
            </g>

            <path id="k8s-flow-repo-argocd" class="project-network-line project-network-flow" d="M300,107 L300,223" fill="none" stroke="var(--diagram-accent)" stroke-width="1"></path>
            <g transform="translate(300, 240)">
              <rect class="project-network-node project-network-node-core" fill="var(--diagram-node-fill)" height="34" rx="5" stroke="var(--diagram-accent)" stroke-width="1" width="140" x="-70" y="-17"></rect>
              <text fill="var(--diagram-accent)" font-family="Inter" font-size="9" text-anchor="middle" dominant-baseline="middle">
                Argo CD
              </text>
            </g>

            <path id="k8s-flow-argocd-cluster" class="project-network-line project-network-flow" d="M300,257 L300,376" fill="none" stroke="var(--diagram-accent)" stroke-width="1"></path>
            <rect class="project-network-boundary" x="80" y="376" width="440" height="150" rx="12" fill="var(--diagram-boundary-fill)" stroke="var(--diagram-boundary-stroke)" stroke-width="1"></rect>
            <text x="98" y="394" fill="var(--diagram-boundary-strong)" font-family="Inter" font-size="9" font-weight="bold">
              k3s Cluster (Bare Metal)
            </text>

            <g transform="translate(170, 432)">
              <rect class="project-network-node project-network-node-app" fill="var(--diagram-node-fill)" height="28" rx="3" stroke="var(--diagram-app-stroke)" stroke-width="1" width="124" x="-62" y="-14"></rect>
              <text fill="var(--diagram-text)" font-family="Inter" font-size="8.25" text-anchor="middle" dominant-baseline="middle">
                Portfolio App
              </text>
            </g>
            <g transform="translate(300, 432)">
              <rect class="project-network-node project-network-node-app" fill="var(--diagram-node-fill)" height="28" rx="3" stroke="var(--diagram-app-stroke)" stroke-width="1" width="98" x="-49" y="-14"></rect>
              <text fill="var(--diagram-text)" font-family="Inter" font-size="8.25" text-anchor="middle" dominant-baseline="middle">
                Immich
              </text>
            </g>
            <g transform="translate(430, 432)">
              <rect class="project-network-node project-network-node-app" fill="var(--diagram-node-fill)" height="28" rx="3" stroke="var(--diagram-app-stroke)" stroke-width="1" width="138" x="-69" y="-14"></rect>
              <text fill="var(--diagram-text)" font-family="Inter" font-size="8.25" text-anchor="middle" dominant-baseline="middle">
                Prom/Graf/Alert
              </text>
            </g>
            <g transform="translate(160, 486)">
              <rect class="project-network-node project-network-node-app" fill="var(--diagram-node-fill)" height="28" rx="3" stroke="var(--diagram-app-stroke)" stroke-width="1" width="108" x="-54" y="-14"></rect>
              <text fill="var(--diagram-text)" font-family="Inter" font-size="8.25" text-anchor="middle" dominant-baseline="middle">
                Uptime Kuma
              </text>
            </g>
            <g transform="translate(300, 486)">
              <rect class="project-network-node project-network-node-app" fill="var(--diagram-node-fill)" height="28" rx="3" stroke="var(--diagram-app-stroke)" stroke-width="1" width="92" x="-46" y="-14"></rect>
              <text fill="var(--diagram-text)" font-family="Inter" font-size="8.25" text-anchor="middle" dominant-baseline="middle">
                Traefik
              </text>
            </g>
            <g transform="translate(440, 486)">
              <rect class="project-network-node project-network-node-app" fill="var(--diagram-node-fill)" height="28" rx="3" stroke="var(--diagram-app-stroke)" stroke-width="1" width="140" x="-70" y="-14"></rect>
              <text fill="var(--diagram-text)" font-family="Inter" font-size="8.25" text-anchor="middle" dominant-baseline="middle">
                Cloudflare Tunnel
              </text>
            </g>

            <circle class="project-network-packet" r="3" fill="var(--diagram-packet)" filter="url(#k8s-packet-glow)">
              <animateMotion dur="4.8s" repeatCount="indefinite" rotate="auto" calcMode="linear" keyPoints="0;1;0" keyTimes="0;0.5;1">
                <mpath href="#k8s-flow-repo-argocd"></mpath>
              </animateMotion>
            </circle>
            <circle class="project-network-packet" r="2.25" fill="var(--diagram-packet)" filter="url(#k8s-packet-glow)">
              <animateMotion dur="4.7s" repeatCount="indefinite" rotate="auto" begin="1.2s" calcMode="linear" keyPoints="0;1;0" keyTimes="0;0.5;1">
                <mpath href="#k8s-flow-argocd-cluster"></mpath>
              </animateMotion>
            </circle>
          </svg>
        </div>
      </div>
    </section>

    <section id="k8s-homelab-platform-stack" class="project-stack reveal-section" style="order: 2;">
      <h4 class="project-stack-title reveal-item" style="--reveal-order: 0;">Infrastructure Stack</h4>

      <div class="project-stack-grid">
        {
          k8sStackGroups.map((group, groupIndex) => (
            <section class="project-stack-group reveal-item" style={`--reveal-order: ${groupIndex + 1};`}>
              <h5 class="project-stack-group-title">
                <span class="project-stack-group-rule" aria-hidden="true"></span>
                {group.label}
              </h5>

              <ul class="project-stack-list">
                {group.items.map((item) => (
                  <li class="project-stack-item">
                    <span class="project-stack-item-dot" aria-hidden="true"></span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </section>
          ))
        }
      </div>
    </section>

    <section id="private-cloud" class="project-feature reveal-section border-t border-cyber-border/20" style="order: 5;">
      <div class="project-feature-heading">
        <div class="project-feature-heading-row">
          <h3 class="project-feature-title reveal-item" style="--reveal-order: 0;">
            Private Cloud Infrastructure
          </h3>
          <a
            class="project-feature-link btn-glow-hover reveal-item"
            href={siteConfig.privateCloudArchitectureUrl}
            target="_blank"
            rel="noopener noreferrer"
            style="--reveal-order: 1;"
          >
            <img
              src="/icons/github.svg"
              alt=""
              aria-hidden="true"
              class="project-feature-link-icon"
              loading="lazy"
            />
            <span>View on GitHub</span>
            <span class="material-symbols-outlined project-feature-link-arrow" aria-hidden="true">
              north_east
            </span>
          </a>
        </div>
        <div class="project-feature-rule reveal-item" style="--reveal-order: 2;" aria-hidden="true">
        </div>
      </div>

      <div class="project-feature-layout">
        <div class="project-feature-details">
          <p class="project-feature-description reveal-item" style="--reveal-order: 3;">
            Designed and deployed a self-hosted private cloud environment focused on secure service
            exposure, reverse proxy routing, monitoring, and deployment automation. The setup uses
            Cloudflare Tunnel, Nginx Proxy Manager, Docker, and Ansible to provide a modular
            foundation for self-hosted applications.
          </p>

          <div class="project-pillars">
            <article class="project-pillar glass-effect reveal-item" style="--reveal-order: 4;">
              <h4 class="project-pillar-title">Infrastructure &amp; Access</h4>
              <ul class="project-pillar-list">
                {
                  infrastructureAccessItems.map((item) => (
                    <li class="project-pillar-item">
                      <span class="project-pillar-arrow" aria-hidden="true">
                        →
                      </span>
                      <span>{item}</span>
                    </li>
                  ))
                }
              </ul>
            </article>

            <article class="project-pillar glass-effect reveal-item" style="--reveal-order: 5;">
              <h4 class="project-pillar-title">Operations &amp; Observability</h4>
              <ul class="project-pillar-list">
                {
                  operationsObservabilityItems.map((item) => (
                    <li class="project-pillar-item">
                      <span class="project-pillar-arrow" aria-hidden="true">
                        →
                      </span>
                      <span>{item}</span>
                    </li>
                  ))
                }
              </ul>
            </article>
          </div>
        </div>

        <div class="project-network-panel glass-effect reveal-item" style="--reveal-order: 6;">
          <div class="project-network-label">
            <div class="project-network-indicator" aria-hidden="true"></div>
            <span>System Architecture</span>
          </div>

          <svg class="project-network-visual" viewBox="0 0 600 550" preserveAspectRatio="xMidYMid meet">
            <defs>
              <filter id="project-packet-glow" x="-200%" y="-200%" width="400%" height="400%">
                <feGaussianBlur stdDeviation="2" result="blur"></feGaussianBlur>
                <feMerge>
                  <feMergeNode in="blur"></feMergeNode>
                  <feMergeNode in="SourceGraphic"></feMergeNode>
                </feMerge>
              </filter>
            </defs>
            <g transform="translate(300, 30)">
              <circle fill="transparent" r="12" stroke="var(--diagram-muted)" stroke-dasharray="2" stroke-width="1"></circle>
              <text
                x="0"
                y="22"
                fill="var(--diagram-muted)"
                font-family="Inter"
                font-size="8"
                text-anchor="middle"
                dominant-baseline="middle"
              >
                User
              </text>
              <circle cx="0" cy="-3.5" r="3" fill="none" stroke="var(--diagram-text)" stroke-width="1"></circle>
              <path
                d="M-5,5.5 C-5,2.5 5,2.5 5,5.5"
                fill="none"
                stroke="var(--diagram-text)"
                stroke-linecap="round"
                stroke-width="1"
              ></path>
            </g>

            <path id="project-flow-edge" class="project-network-line project-network-flow" d="M300,42 L300,67" fill="none" stroke="var(--diagram-accent)" stroke-width="1"></path>

            <g transform="translate(300, 80)">
              <rect class="project-network-node project-network-node-edge" fill="var(--diagram-node-fill)" height="26" rx="4" stroke="var(--diagram-accent)" stroke-width="1" width="110" x="-55" y="-13"></rect>
              <text
                fill="var(--diagram-accent)"
                font-family="Inter"
                font-size="9"
                text-anchor="middle"
                dominant-baseline="middle"
              >
                Cloudflare Edge
              </text>
            </g>

            <path
              id="project-flow-tunnel"
              class="project-network-line project-network-flow"
              d="M300,93 L300,198"
              fill="none"
              stroke="var(--diagram-accent)"
              stroke-dasharray="4"
              stroke-width="1.5"
            ></path>
            <text x="350" y="125" fill="var(--diagram-accent)" font-family="Inter" font-size="7" opacity="0.6" text-anchor="middle">
              Cloudflare Tunnel
            </text>

            <rect
              class="project-network-boundary"
              x="30"
              y="165"
              width="540"
              height="342"
              rx="12"
              fill="var(--diagram-boundary-fill)"
              stroke="var(--diagram-boundary-stroke)"
              stroke-width="1"
            ></rect>
            <g transform="translate(18, 160)" aria-hidden="true">
              <rect x="0" y="0" width="24" height="30" rx="3" fill="var(--diagram-server-fill)" stroke="var(--diagram-boundary-strong)" stroke-width="1"></rect>
              <rect x="4" y="5" width="16" height="7" rx="1.5" fill="none" stroke="var(--diagram-accent)" stroke-width="1"></rect>
              <rect x="4" y="17" width="16" height="7" rx="1.5" fill="none" stroke="var(--diagram-accent)" stroke-width="1"></rect>
              <circle cx="7" cy="8.5" r="1" fill="var(--diagram-accent)"></circle>
              <circle cx="7" cy="20.5" r="1" fill="var(--diagram-accent)"></circle>
              <path d="M10 27 H14" stroke="var(--diagram-accent)" stroke-linecap="round" stroke-width="1"></path>
            </g>
            <text x="50" y="180" fill="var(--diagram-boundary-strong)" font-family="Inter" font-size="9" font-weight="bold">
              Server
            </text>
            <rect
              class="project-network-boundary project-network-boundary-soft"
              x="72"
              y="191"
              width="456"
              height="287"
              rx="10"
              fill="transparent"
              stroke="var(--diagram-boundary-soft)"
              stroke-dasharray="4 4"
              stroke-width="1"
            ></rect>
            <image href="/icons/docker.svg" x="66" y="184" width="22" height="22"></image>
            <text x="92" y="197" fill="var(--diagram-boundary-strong)" font-family="Inter" font-size="8" font-weight="bold" dominant-baseline="middle">
              Docker
            </text>
            <rect
              class="project-network-zone"
              x="168"
              y="196"
              width="264"
              height="126"
              rx="10"
              fill="var(--diagram-zone-fill)"
              stroke="var(--diagram-zone-stroke)"
              stroke-dasharray="4 4"
              stroke-width="1"
            ></rect>
            <text x="182" y="210" fill="var(--diagram-zone-text)" font-family="Inter" font-size="8" font-weight="bold">
              Ingress DMZ
            </text>
            <g transform="translate(300, 220)">
              <circle class="project-network-node project-network-node-core" fill="var(--diagram-node-fill)" r="22" stroke="var(--diagram-accent)" stroke-width="1"></circle>
              <text
                y="32"
                fill="var(--diagram-text)"
                font-family="Inter"
                font-size="8"
                text-anchor="middle"
                dominant-baseline="middle"
              >
                cloudflared
              </text>
              <image href="/icons/cloudflare.svg" x="-9" y="-9" width="18" height="18"></image>
            </g>

            <path id="project-flow-bridge" class="project-network-line project-network-flow" d="M300,242 L300,285" fill="none" stroke="var(--diagram-accent)" stroke-width="1"></path>
            <text x="240" y="265" fill="var(--diagram-muted)" font-family="Inter" font-size="7" text-anchor="middle">
              docker-cloudflared bridge
            </text>

            <g transform="translate(300, 300)">
              <rect class="project-network-node project-network-node-core" fill="var(--diagram-node-fill)" height="30" rx="4" stroke="var(--diagram-accent)" stroke-width="1" width="170" x="-85" y="-15"></rect>
              <text
                fill="var(--diagram-accent)"
                font-family="Inter"
                font-size="8"
                text-anchor="middle"
                dominant-baseline="middle"
              >
                Nginx Proxy Manager
              </text>
            </g>

            <path id="project-flow-vaultwarden" class="project-network-line project-network-flow" d="M300,315 L120,388" fill="none" stroke="var(--diagram-accent)" stroke-width="1"></path>
            <path id="project-flow-nextcloud" class="project-network-line project-network-flow" d="M300,315 L240,388" fill="none" stroke="var(--diagram-accent)" stroke-width="1"></path>
            <path id="project-flow-grafana" class="project-network-line project-network-flow" d="M300,315 L480,388" fill="none" stroke="var(--diagram-accent)" stroke-width="1"></path>
            <path id="project-flow-portfolio" class="project-network-line project-network-flow" d="M300,315 L300,422 L180,422 L180,436" fill="none" stroke="var(--diagram-accent)" stroke-width="1"></path>
            <path id="project-flow-kuma" class="project-network-line project-network-flow" d="M300,315 L300,422 L420,422 L420,436" fill="none" stroke="var(--diagram-accent)" stroke-width="1"></path>
            <text x="300" y="350" fill="var(--diagram-muted)" font-family="Inter" font-size="7" text-anchor="middle">
              docker-proxy network
            </text>

            <g transform="translate(120, 400)">
              <rect class="project-network-node project-network-node-app" fill="var(--diagram-node-fill)" height="25" rx="2" stroke="var(--diagram-app-stroke)" stroke-width="1" width="85" x="-42" y="-12"></rect>
              <text
                fill="var(--diagram-text)"
                font-family="Inter"
                font-size="8"
                text-anchor="middle"
                dominant-baseline="middle"
              >
                Vaultwarden
              </text>
            </g>

            <g transform="translate(240, 400)">
              <rect class="project-network-node project-network-node-app" fill="var(--diagram-node-fill)" height="25" rx="2" stroke="var(--diagram-app-stroke)" stroke-width="1" width="85" x="-42" y="-12"></rect>
              <text
                fill="var(--diagram-text)"
                font-family="Inter"
