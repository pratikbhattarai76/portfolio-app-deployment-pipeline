---
const toolingGroups = [
  {
    title: 'Cloud & Infrastructure',
    items: ['AWS (EC2, S3, IAM, ALB)', 'Cloudflare'],
  },
  {
    title: 'Containerization',
    items: ['Docker', 'Docker Compose', 'Kubernetes'],
  },
  {
    title: 'Infrastructure as Code',
    items: ['Terraform', 'Ansible', 'Helm'],
  },
  {
    title: 'CI/CD & Automation',
    items: ['GitHub Actions', 'GHCR', 'Argo CD'],
  },
  {
    title: 'Languages',
    items: ['Python', 'Bash', 'JavaScript'],
  },
  {
    title: 'Monitoring',
    items: ['Prometheus', 'Grafana', 'Alertmanager', 'Node Exporter', 'cAdvisor'],
  },
  {
    title: 'Systems & Networking',
    items: ['Linux', 'Traefik', 'Nginx Proxy Manager (Nginx)'],
  },
  {
    title: 'Version Control',
    items: ['Git', 'GitHub'],
  },
];
---

<section class="tooling-section">
  <div class="tooling-shell reveal-section">
    <h2 class="tooling-title reveal-item" style="--reveal-order: 0;">Top Skills</h2>
    <div class="tooling-groups">
      {
        toolingGroups.map((group, groupIndex) => (
          <article class="tooling-group reveal-item" style={`--reveal-order: ${groupIndex + 1};`}>
            <h3 class="tooling-group-title">{group.title}</h3>
            <ul class="tooling-group-items">
              {group.items.map((item) => (
                <li class="tooling-pill">{item}</li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>
  </div>
</section>
