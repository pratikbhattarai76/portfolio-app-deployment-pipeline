---
const desktopNavItems = [
  { href: '#deployments', label: 'Services' },
];

const mobileNavItems = [
  { href: '#deployments', label: 'Services' },
  { href: '#projects', label: 'Projects' },
  { href: '#contact', label: 'Contact' },
];

const projectNavItems = [
  { href: '#private-cloud', label: 'Private Cloud Infrastructure' },
  { href: '#malaideu', label: 'MalaiDeu' },
  { href: '#portfolio-application', label: 'Portfolio Application' },
];
---

<header
  id="navbar"
  class="site-navbar fixed top-0 z-50 w-full border-b border-cyber-border glass-effect"
>
  <div class="site-progress" aria-hidden="true">
    <span id="site-progress-bar" class="site-progress-bar"></span>
  </div>

  <nav
    class="navbar-shell mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 sm:px-6"
    aria-label="Primary"
  >
    <a class="navbar-brand flex items-center gap-3" href="#hero" aria-label="Jump to hero section">
      <img
        src="/images/profile.jpg"
        alt="Pratik"
        class="navbar-avatar h-8 w-8 rounded-full border border-cyber-accent object-cover"
        loading="eager"
      />
      <span class="hidden text-xs font-semibold tracking-widest sm:block">
        Pratik
      </span>
    </a>

    <div class="navbar-actions">
      <div class="navbar-links navbar-links-desktop" aria-label="Section navigation">
        {
          desktopNavItems.map(({ href, label }) => (
            <a class="navbar-link" data-nav-link href={href}>
              {label}
            </a>
          ))
        }

        <div class="navbar-link-group">
          <a class="navbar-link navbar-link-group-trigger" data-nav-link href="#projects">
            Projects
          </a>

          <div class="navbar-projects-menu glass-effect" aria-label="Project navigation">
            {
              projectNavItems.map(({ href, label }) => (
                <a class="navbar-project-link" href={href}>
                  {label}
                </a>
              ))
            }
          </div>
        </div>

        <a class="navbar-link" data-nav-link href="#contact">
          Contact
        </a>
      </div>

      <button class="theme-toggle" data-theme-toggle type="button" aria-label="Activate light mode">
        <span class="theme-toggle-track" aria-hidden="true">
          <span class="theme-toggle-stars">
            <span class="theme-toggle-star theme-toggle-star-1"></span>
            <span class="theme-toggle-star theme-toggle-star-2"></span>
            <span class="theme-toggle-star theme-toggle-star-3"></span>
          </span>
          <span class="theme-toggle-cloud"></span>
          <span class="theme-toggle-thumb">
            <span class="theme-toggle-icon theme-toggle-sun">
              <span class="theme-toggle-sun-core"></span>
              <span class="theme-toggle-sun-ray theme-toggle-sun-ray-1"></span>
              <span class="theme-toggle-sun-ray theme-toggle-sun-ray-2"></span>
              <span class="theme-toggle-sun-ray theme-toggle-sun-ray-3"></span>
              <span class="theme-toggle-sun-ray theme-toggle-sun-ray-4"></span>
            </span>
            <span class="theme-toggle-icon theme-toggle-moon"></span>
          </span>
        </span>
        <span class="theme-toggle-copy" data-theme-toggle-copy>Dark</span>
      </button>

      <button
        class="navbar-menu-toggle"
        data-nav-toggle
        type="button"
        aria-expanded="false"
        aria-controls="navbar-mobile-panel"
        aria-label="Open navigation menu"
      >
        <span class="sr-only">Toggle navigation menu</span>
        <span class="navbar-menu-toggle-line"></span>
        <span class="navbar-menu-toggle-line"></span>
        <span class="navbar-menu-toggle-line"></span>
      </button>
    </div>
  </nav>

  <div
    id="navbar-mobile-panel"
    class="navbar-mobile-panel"
    data-nav-panel
    aria-label="Mobile section navigation"
    aria-hidden="true"
  >
    <div class="navbar-mobile-links glass-effect">
      {
        mobileNavItems.map(({ href, label }) => (
          <a class="navbar-link navbar-link-mobile" data-nav-link href={href}>
            {label}
          </a>
        ))
      }
    </div>
  </div>
</header>
