---
import '../styles/global.css';
import Navbar from '../components/site/Navbar.astro';
import { siteConfig } from '../config/site';

const canonicalUrl = new URL(Astro.url.pathname, siteConfig.siteUrl).toString();
const socialImageUrl = new URL('/images/profile.jpg', siteConfig.siteUrl).toString();
const pageTitle = `${siteConfig.name} | ${siteConfig.title}`;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={siteConfig.description} />
		<meta name="theme-color" content="#020617" />
		<script is:inline>
			(() => {
				const themeStorageKey = 'portfolio-theme';
				const root = document.documentElement;
				let theme = 'dark';

				try {
					const storedTheme = window.localStorage.getItem(themeStorageKey);

					if (storedTheme === 'light' || storedTheme === 'dark') {
						theme = storedTheme;
					} else if (window.matchMedia?.('(prefers-color-scheme: light)').matches) {
						theme = 'light';
					}
				} catch {}

				root.dataset.theme = theme;
				root.style.colorScheme = theme;
			})();
		</script>
		<meta name="robots" content="index,follow" />
		<link rel="canonical" href={canonicalUrl} />
		<meta property="og:type" content="website" />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={siteConfig.description} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:image" content={socialImageUrl} />
		<meta property="og:site_name" content={siteConfig.name} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={pageTitle} />
		<meta name="twitter:description" content={siteConfig.description} />
		<meta name="twitter:image" content={socialImageUrl} />
		<script is:inline>
			(() => {
				const navigationEntries =
					typeof performance.getEntriesByType === 'function'
						? performance.getEntriesByType('navigation')
						: [];
				const navigationEntry = navigationEntries[0];
				const legacyNavigation =
					typeof Reflect?.get === 'function' ? Reflect.get(performance, 'navigation') : undefined;
				const legacyNavigationTypeValue =
					legacyNavigation && typeof Reflect?.get === 'function'
						? Reflect.get(legacyNavigation, 'type')
						: undefined;
				const legacyNavigationType =
					typeof legacyNavigationTypeValue === 'number'
						? legacyNavigationTypeValue
						: undefined;
				const isReloadNavigation =
					(Boolean(navigationEntry) &&
						'type' in navigationEntry &&
						navigationEntry.type === 'reload') ||
					legacyNavigationType === 1;

				if ('scrollRestoration' in history) {
					history.scrollRestoration = 'manual';
				}

				if (isReloadNavigation) {
					document.documentElement.dataset.scrollReset = 'reload';
				}
			})();
		</script>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Manrope:wght@400;500;600;700;800&display=swap"
			rel="stylesheet"
		/>
		<link
			href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght@100..700&display=swap"
			rel="stylesheet"
		/>
		<title>{pageTitle}</title>
	</head>
	<body class="site-body">
		<a class="skip-link" href="#main-content">Skip to content</a>
		<div class="site-grid-layer grid-bg" aria-hidden="true"></div>
		<div class="site-ambient site-ambient-top" aria-hidden="true"></div>
		<div class="site-ambient site-ambient-bottom" aria-hidden="true"></div>
		<div class="site-scanline-layer" aria-hidden="true">
			<div class="scanline"></div>
		</div>
		<Navbar />
		<slot />
		<script is:inline>
			const themeStorageKey = 'portfolio-theme';
			const darkThemeColor = '#020617';
			const lightThemeColor = '#f8fafc';
			const root = document.documentElement;
			const themeMeta = document.querySelector('meta[name="theme-color"]');
			const themeToggleButtons = Array.from(document.querySelectorAll('[data-theme-toggle]'));
			const themeToggleCopies = Array.from(document.querySelectorAll('[data-theme-toggle-copy]'));
			const reducedMotion =
				window.matchMedia?.('(prefers-reduced-motion: reduce)').matches ?? false;
			const systemThemeQuery = window.matchMedia?.('(prefers-color-scheme: light)');
			let themeAnimationTimer = 0;

			const persistTheme = (theme) => {
				try {
					window.localStorage.setItem(themeStorageKey, theme);
				} catch {}
			};

			const getStoredTheme = () => {
				try {
					const storedTheme = window.localStorage.getItem(themeStorageKey);
					return storedTheme === 'light' || storedTheme === 'dark' ? storedTheme : null;
				} catch {
					return null;
				}
			};

			const getSystemTheme = () => (systemThemeQuery?.matches ? 'light' : 'dark');

			const updateThemeUi = (theme) => {
				root.dataset.theme = theme;
				root.style.colorScheme = theme;

				if (themeMeta instanceof HTMLMetaElement) {
					themeMeta.setAttribute('content', theme === 'light' ? lightThemeColor : darkThemeColor);
				}

				themeToggleButtons.forEach((button) => {
					const nextTheme = theme === 'dark' ? 'light' : 'dark';
					button.dataset.theme = theme;
					button.setAttribute('aria-pressed', String(theme === 'light'));
					button.setAttribute('aria-label', `Activate ${nextTheme} mode`);
					button.setAttribute('title', `Switch to ${nextTheme} mode`);
				});

				themeToggleCopies.forEach((copy) => {
					copy.textContent = theme === 'dark' ? 'Dark' : 'Light';
				});
			};

			const applyTheme = (theme, { animate = false, persist = false } = {}) => {
				if (animate && !reducedMotion) {
					root.classList.add('theme-switching');
					window.clearTimeout(themeAnimationTimer);
					themeAnimationTimer = window.setTimeout(() => {
						root.classList.remove('theme-switching');
					}, 480);
				}

				updateThemeUi(theme);

				if (persist) {
					persistTheme(theme);
				}
			};

			const switchTheme = (nextTheme) => {
				if (
					!reducedMotion &&
					typeof document.startViewTransition === 'function'
				) {
					document.startViewTransition(() => {
						applyTheme(nextTheme, { animate: true, persist: true });
					});
					return;
				}

				applyTheme(nextTheme, { animate: true, persist: true });
			};

			updateThemeUi(getStoredTheme() ?? getSystemTheme());

			themeToggleButtons.forEach((button) => {
				button.addEventListener('click', () => {
					const currentTheme = root.dataset.theme === 'light' ? 'light' : 'dark';
					switchTheme(currentTheme === 'dark' ? 'light' : 'dark');
				});
			});

			systemThemeQuery?.addEventListener?.('change', ({ matches }) => {
				if (getStoredTheme()) {
					return;
				}

				applyTheme(matches ? 'light' : 'dark');
			});

			const shouldResetScrollOnLoad = document.documentElement.dataset.scrollReset === 'reload';
			const resetPageScroll = () => {
				window.scrollTo({ top: 0, left: 0, behavior: 'auto' });

				requestAnimationFrame(() => {
					window.scrollTo({ top: 0, left: 0, behavior: 'auto' });
				});

				window.setTimeout(() => {
					window.scrollTo({ top: 0, left: 0, behavior: 'auto' });
				}, 0);
			};

			if (shouldResetScrollOnLoad) {
				resetPageScroll();
				window.addEventListener('load', resetPageScroll, { once: true });
				window.addEventListener('pageshow', resetPageScroll, { once: true });
			}

			window.addEventListener(
				'load',
				() => {
					if ('scrollRestoration' in history) {
						history.scrollRestoration = 'auto';
					}
				},
				{ once: true }
			);

			const navbar = document.getElementById('navbar');
			const progressBar = document.getElementById('site-progress-bar');
			const navToggle = document.querySelector('[data-nav-toggle]');
			const navPanel = document.querySelector('[data-nav-panel]');
			const navLinks = Array.from(document.querySelectorAll('[data-nav-link]'));
			const revealElements = Array.from(document.querySelectorAll('.reveal-section'));
			const compactViewportQuery = window.matchMedia?.(
				'(max-width: 900px), (hover: none) and (pointer: coarse)'
			);
			let mobileNavOpen = false;
			let revealObserver;
			let revealBootstrapped = false;
			let revealBootTimer = 0;
			const setRevealDelay = (element, order = 0) => {
				element.style.setProperty('--reveal-section-delay', `${Math.max(order, 0) * 120}ms`);
			};
			const revealSection = (element, order = 0) => {
				if (!(element instanceof HTMLElement) || element.classList.contains('reveal-visible')) {
					return;
				}

				setRevealDelay(element, order);
				element.classList.add('reveal-visible');
			};
			const getNavbarOffset = () => (navbar instanceof HTMLElement ? navbar.offsetHeight + 24 : 88);
			const getRevealStart = () => {
				const compactViewport = compactViewportQuery?.matches ?? false;

				return window.innerHeight * (compactViewport ? 0.96 : 0.9);
			};
			const setMobileNavOpen = (open) => {
				if (
					!(navbar instanceof HTMLElement) ||
					!(navToggle instanceof HTMLButtonElement) ||
					!(navPanel instanceof HTMLElement)
				) {
					return;
				}

				mobileNavOpen = open;
				navbar.classList.toggle('site-navbar-menu-open', open);
				document.body.classList.toggle('site-body-nav-open', open);
				navToggle.setAttribute('aria-expanded', String(open));
				navToggle.setAttribute(
					'aria-label',
					open ? 'Close navigation menu' : 'Open navigation menu'
				);
				navPanel.setAttribute('aria-hidden', String(!open));
			};

			const syncRevealVisibility = () => {
				if (reducedMotion || revealElements.length === 0) {
					revealElements.forEach((element) => revealSection(element));
					return;
				}

				const revealStart = getRevealStart();
				const revealEnd = -window.innerHeight * 0.18;
				const pendingVisibleElements = [];

				revealElements.forEach((element) => {
					if (element.classList.contains('reveal-visible')) {
						return;
					}

					const bounds = element.getBoundingClientRect();
					const isNearViewport = bounds.top <= revealStart && bounds.bottom >= revealEnd;

					if (isNearViewport) {
						pendingVisibleElements.push(element);
					}
				});

				pendingVisibleElements.forEach((element, index) => revealSection(element, index));
			};
			const observeRevealVisibility = () => {
				if (reducedMotion || revealElements.length === 0) {
					syncRevealVisibility();
					return;
				}

				if (typeof IntersectionObserver !== 'function') {
					syncRevealVisibility();
					return;
				}

				revealObserver?.disconnect();

				const compactViewport = compactViewportQuery?.matches ?? false;
				revealObserver = new IntersectionObserver(
					(entries) => {
						const intersectingEntries = entries
							.filter(
								(entry) =>
									entry.isIntersecting &&
									entry.target instanceof HTMLElement &&
									!entry.target.classList.contains('reveal-visible')
							)
							.sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);

						intersectingEntries.forEach((entry, index) => {
							if (!(entry.target instanceof HTMLElement)) {
								return;
							}

							revealSection(entry.target, index);
							revealObserver?.unobserve(entry.target);
						});
					},
					{
						rootMargin: compactViewport ? '0px 0px -6% 0px' : '0px 0px -12% 0px',
						threshold: compactViewport ? 0.14 : 0.18,
					}
				);

				revealElements.forEach((element) => {
					if (element.classList.contains('reveal-visible')) {
						return;
					}

					revealObserver?.observe(element);
				});
			};

			document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
				anchor.addEventListener('click', (event) => {
					const href = anchor.getAttribute('href');

					if (!href || href === '#') {
						return;
					}

					const target = document.querySelector(href);

					if (!(target instanceof HTMLElement)) {
						return;
					}

					event.preventDefault();

					const top = target.getBoundingClientRect().top + window.scrollY - getNavbarOffset();

					window.scrollTo({
						top,
						behavior: reducedMotion ? 'auto' : 'smooth',
					});

					if (mobileNavOpen) {
						setMobileNavOpen(false);
					}
				});
			});

			const updateProgress = () => {
				if (!(progressBar instanceof HTMLElement)) {
					return;
				}

				const scrollableHeight = document.documentElement.scrollHeight - window.innerHeight;
				const progress = scrollableHeight > 0 ? window.scrollY / scrollableHeight : 0;
				progressBar.style.transform = `scaleX(${Math.min(Math.max(progress, 0), 1)})`;
			};

			const updateNavbarState = () => {
				if (!(navbar instanceof HTMLElement)) {
					return;
				}

				navbar.classList.toggle('site-navbar-scrolled', window.scrollY > 18);
			};

			const setActiveLink = (sectionId) => {
				navLinks.forEach((link) => {
					const isActive = sectionId ? link.getAttribute('href') === `#${sectionId}` : false;
					link.classList.toggle('navbar-link-active', isActive);

					if (isActive) {
						link.setAttribute('aria-current', 'true');
					} else {
						link.removeAttribute('aria-current');
					}
				});
			};

			const sectionTargets = navLinks.reduce((items, link) => {
				const href = link.getAttribute('href');

				if (!href) {
					return items;
				}

				const section = document.querySelector(href);

				if (!(section instanceof HTMLElement)) {
					return items;
				}

				items.push({ link, section });
				return items;
			}, []);

			const setActiveLinkFromViewport = () => {
				if (sectionTargets.length === 0) {
					return;
				}

				const viewportLine = window.scrollY + getNavbarOffset() + 48;
				const currentSection =
					sectionTargets
						.slice()
						.reverse()
						.find(({ section }) => section.offsetTop <= viewportLine) ?? null;

				setActiveLink(currentSection?.section.id ?? null);
			};

			const syncActiveLinkFromScroll = () => {
				if (sectionTargets.length === 0) {
					return;
				}

				const firstSectionTop = sectionTargets[0].section.offsetTop - getNavbarOffset() - 24;

				if (window.scrollY < firstSectionTop) {
					setActiveLink(null);
					return;
				}

				setActiveLinkFromViewport();
			};

			if (navToggle instanceof HTMLButtonElement && navPanel instanceof HTMLElement) {
				navToggle.addEventListener('click', () => {
					setMobileNavOpen(!mobileNavOpen);
				});

				document.addEventListener('keydown', (event) => {
					if (event.key === 'Escape' && mobileNavOpen) {
						setMobileNavOpen(false);
						navToggle.focus();
					}
				});

				document.addEventListener('click', (event) => {
					if (!mobileNavOpen || !(event.target instanceof Node)) {
						return;
					}

					if (navbar instanceof HTMLElement && !navbar.contains(event.target)) {
						setMobileNavOpen(false);
					}
				});
			}

			if (sectionTargets.length > 0) {
				syncActiveLinkFromScroll();
			}

			const syncShell = () => {
				if (revealBootstrapped || reducedMotion || revealElements.length === 0) {
					syncRevealVisibility();
				}

				updateProgress();
				updateNavbarState();
				syncActiveLinkFromScroll();
			};
			let shellFrame = 0;
			const requestShellSync = () => {
				if (shellFrame) {
					return;
				}

				shellFrame = window.requestAnimationFrame(() => {
					shellFrame = 0;
					syncShell();
				});
			};

			const finalizeRevealSetup = () => {
				if (revealBootstrapped) {
					return;
				}

				revealBootstrapped = true;
				window.clearTimeout(revealBootTimer);
				syncRevealVisibility();
				observeRevealVisibility();
				requestShellSync();
			};

			if (revealElements.length > 0) {
				root.dataset.revealReady = 'true';
				window.requestAnimationFrame(() => {
					window.requestAnimationFrame(finalizeRevealSetup);
				});
				revealBootTimer = window.setTimeout(finalizeRevealSetup, 220);
			} else {
				finalizeRevealSetup();
			}

			syncShell();
			window.addEventListener('scroll', requestShellSync, { passive: true });
			window.addEventListener('resize', () => {
				if (!(compactViewportQuery?.matches ?? false) && mobileNavOpen) {
					setMobileNavOpen(false);
				}

				if (revealBootstrapped) {
					observeRevealVisibility();
				}

				requestShellSync();
			});
		</script>
	</body>
</html>
