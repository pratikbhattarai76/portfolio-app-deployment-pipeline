---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<main id="main-content">
		<section id="hero" class="pt-24">
			<h1 class="text-4xl font-bold tracking-tight">Pratik Bhattarai</h1>
			<p class="mt-2 text-slate-400">DevOps &amp; Cloud Engineer</p>
		</section>

		<section id="infrastructure" class="pt-24">
			<h2 class="text-2xl font-bold">Infrastructure</h2>
		</section>

		<section id="deployments" class="pt-24">
			<h2 class="text-2xl font-bold">Deployments</h2>
		</section>

		<section id="projects" class="pt-24">
			<h2 class="text-2xl font-bold">Projects</h2>
		</section>

		<section id="contact" class="pt-24 pb-24">
			<h2 class="text-2xl font-bold">Contact</h2>
		</section>
	</main>
</Layout>
